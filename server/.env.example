# Copy this file to .env and fill in your values
# Never commit .env to git — it contains secrets

# Get this from MongoDB Atlas (free tier) or use local:
# Local:  mongodb://localhost:27017/habittracker
# Atlas:  mongodb+srv://<username>:<password>@cluster.mongodb.net/habittracker
MONGO_URI=mongodb://localhost:27017/habittracker

# Secret used to sign JWTs. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

PORT=5000

# Comma-separated list of origins allowed to call this API.
# Local dev defaults to the Vite ports if unset — only needed for deployed environments.
# CORS_ORIGINS=https://cadence.vercel.app

# Max total accounts allowed to sign up. Unset = unlimited (dev/test default).
# Not tied to a specific hosting quota — MongoDB Atlas's free tier is capped by
# storage (512MB), not user count, so this is really just a safety net against
# an open public signup form rather than a precise technical requirement.
# MAX_USERS=20

# Sends the daily habit reminder email. Get an API key from resend.com (free
# tier: 3,000 emails/month). REMINDER_FROM_EMAIL must be an address on a
# domain you've verified with Resend (their sandbox domain works for testing).
RESEND_API_KEY=
REMINDER_FROM_EMAIL=

# Shared secret the GitHub Actions cron workflow sends as the x-cron-secret
# header when it calls POST /api/cron/habit-reminders. Generate one the same
# way as JWT_SECRET above, then add it as a repo secret in GitHub too.
CRON_SECRET=
